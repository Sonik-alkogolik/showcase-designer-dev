server {
    server_name e-tgo.ru www.e-tgo.ru;

    root /var/www/showcase-designer/public;
    index index.html;

    # Security: hidden files
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    location ~ ^/\.well-known/(.*)$ {
        allow all;
        root /var/www/showcase-designer/public;
        try_files $uri =404;
    }

    # Telegram webhook through dedicated reverse proxy route
    location = /api/telegram/webhook {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;

        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Port $server_port;

        proxy_connect_timeout 5s;
        proxy_send_timeout 30s;
        proxy_read_timeout 30s;
        client_max_body_size 1m;

        access_log /var/log/nginx/telegram_webhook_access.log;
        error_log  /var/log/nginx/telegram_webhook_error.log warn;
    }

    # Telegram Web App - SPA
    location /app {
        try_files $uri $uri/ /index.html;
    }

    # Main routing (SPA)
    location / {
        try_files $uri $uri/ /index.html;
    }

    # API through Laravel (PHP)
    location /api/ {
        try_files $uri $uri/ /index.php?$query_string;
    }

    # Admin through Laravel (PHP)
    location /admin {
        try_files $uri $uri/ /index.php?$query_string;
    }

    # PHP handling
    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/run/php/php8.2-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
    }

    # Sensitive files deny
    location ~ /\.(env|git|htaccess|htpasswd) {
        deny all;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/e-tgo.ru/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/e-tgo.ru/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}

server {
    if ($host = www.e-tgo.ru) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    if ($host = e-tgo.ru) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80;
    server_name e-tgo.ru www.e-tgo.ru;
    return 404; # managed by Certbot
}
